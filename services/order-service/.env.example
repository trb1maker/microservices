HTTP_ADDR=:8080
DATABASE_URL=postgres://orders:orders@localhost:5432/orders?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=tls://localhost:4222
USE_MEMORY=false
LOG_LEVEL=info
LOG_FORMAT=json
OTEL_SERVICE_NAME=order-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SDK_DISABLED=false
METRICS_PATH=/metrics
ACTIVE_ORDERS_REFRESH_SEC=30

JWT_SECRET=dev-jwt-secret-minimum-32-characters-long
JWT_TTL=24h
TLS_CERT_FILE=deploy/certs/order-service/server.crt
TLS_KEY_FILE=deploy/certs/order-service/server.key
TLS_CLIENT_CA_FILE=deploy/certs/ca/ca.crt
NATS_TLS_CERT_FILE=deploy/certs/order-service/client.crt
NATS_TLS_KEY_FILE=deploy/certs/order-service/client.key
NATS_TLS_CA_FILE=deploy/certs/ca/ca.crt
MTLS_SERVICE_CNS=order-service,payment-service

