# PostgreSQL
POSTGRES_USER=orders
POSTGRES_PASSWORD=orders
POSTGRES_DB=orders

# order-service (docker compose network)
HTTP_ADDR=:8080
DATABASE_URL=postgres://orders:orders@postgres:5432/orders?sslmode=disable
REDIS_ADDR=redis:6379
NATS_URL=tls://nats:4222
LOG_LEVEL=info
LOG_FORMAT=json
OTEL_SERVICE_NAME=order-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SDK_DISABLED=false
METRICS_PATH=/metrics
ACTIVE_ORDERS_REFRESH_SEC=30

# Security
JWT_SECRET=dev-jwt-secret-minimum-32-characters-long
JWT_TTL=24h
TLS_CERT_FILE=/certs/server.crt
TLS_KEY_FILE=/certs/server.key
TLS_CLIENT_CA_FILE=/certs/ca.crt
NATS_TLS_CERT_FILE=/certs/client.crt
NATS_TLS_KEY_FILE=/certs/client.key
NATS_TLS_CA_FILE=/certs/ca.crt
MTLS_SERVICE_CNS=order-service,payment-service

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin

# Jaeger
COLLECTOR_OTLP_ENABLED=true

# postgres-exporter
POSTGRES_EXPORTER_DATA_SOURCE_NAME=postgresql://orders:orders@postgres:5432/orders?sslmode=disable
